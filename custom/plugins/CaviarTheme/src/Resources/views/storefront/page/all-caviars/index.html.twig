    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var slider = document.querySelector('[data-all-caviars-slider]');
        if (!slider) return;
        var prev = document.querySelector('[data-all-caviars-prev]');
        var next = document.querySelector('[data-all-caviars-next]');
        var card = slider.querySelector('.caviar-all-caviars-products__card');
        if (!card) return;

        var step = function () {
          var gap = parseFloat(window.getComputedStyle(slider).gap || '0');
          return card.getBoundingClientRect().width + gap;
        };

        if (prev) {
          prev.addEventListener('click', function () {
            slider.scrollBy({ left: -step(), behavior: 'smooth' });
          });
        }

        if (next) {
          next.addEventListener('click', function () {
            slider.scrollBy({ left: step(), behavior: 'smooth' });
          });
        }

        var bindCardNavigation = function (selector) {
          var cards = document.querySelectorAll(selector);
          cards.forEach(function (card) {
            var link = card.querySelector('a.caviar-home-featured-card__media-link, a.caviar-all-caviars-species-card__media-link');
            if (!link || !link.href) return;

            card.style.cursor = 'pointer';

            card.addEventListener('click', function (event) {
              if (event.target.closest('a, button, input, select, textarea, label')) return;
              window.location.href = link.href;
            });

            card.addEventListener('keydown', function (event) {
              if (event.key !== 'Enter' && event.key !== ' ') return;
              if (event.target.closest('a, button, input, select, textarea, label')) return;
              event.preventDefault();
              window.location.href = link.href;
            });

            card.setAttribute('tabindex', '0');
            card.setAttribute('role', 'link');
            card.setAttribute('aria-label', link.getAttribute('aria-label') || 'Voir le produit');
          });
        };

        bindCardNavigation('.caviar-all-caviars-products__card');
        bindCardNavigation('.caviar-all-caviars-species-card');

        var filterItems = document.querySelectorAll('[data-filter-item]');
        if (!filterItems.length) return;

        var closeAllFilters = function (except) {
          filterItems.forEach(function (item) {
            if (except && item === except) return;
            var button = item.querySelector('[data-filter-trigger]');
            var panel = item.querySelector('.caviar-all-caviars-products__filter-panel');
            if (!button || !panel) return;
            button.setAttribute('aria-expanded', 'false');
            panel.hidden = true;
          });
        };

        filterItems.forEach(function (item) {
          var button = item.querySelector('[data-filter-trigger]');
          var panel = item.querySelector('.caviar-all-caviars-products__filter-panel');
          if (!button || !panel) return;

          button.addEventListener('click', function (event) {
            event.stopPropagation();
            var expanded = button.getAttribute('aria-expanded') === 'true';
            closeAllFilters(item);
            button.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            panel.hidden = expanded;
          });
        });

        document.addEventListener('click', function () {
          closeAllFilters();
        });
      });
    </script>
