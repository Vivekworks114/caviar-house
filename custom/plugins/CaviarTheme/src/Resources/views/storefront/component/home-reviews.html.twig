<section class="caviar-home-reviews" aria-label="Avis client placeholder">
    <div class="caviar-home-reviews__container">
        <div class="caviar-home-reviews__header">
            <h2 class="caviar-home-reviews__title">Avis client placeholder</h2>
            <img
                src="{{ asset('bundles/caviartheme/assets/img/avis-logo.png') }}"
                class="caviar-home-reviews__badge-logo"
                alt="Avis clients"
                loading="lazy"
            >
        </div>

        <div class="caviar-home-reviews__track-wrap">
            <button class="caviar-home-reviews__arrow caviar-home-reviews__arrow--left" type="button" aria-label="Previous reviews" data-reviews-prev>&lsaquo;</button>

            {% set testimonials = [
                {
                    stars: '★★★★★',
                    date: 'JJ/MM/AAAA',
                    text: 'Rhoncus morbi et augue nec, in id ullamcorper at sit. Condimentum sit nunc in eros scelerisque sed.',
                    author: 'Anonyme'
                },
                {
                    stars: '★★★★★',
                    date: 'JJ/MM/AAAA',
                    text: 'Rhoncus morbi et augue nec, in id ullamcorper at sit. Condimentum sit nunc in eros scelerisque sed.',
                    author: 'Anonyme'
                },
                {
                    stars: '★★★★☆',
                    date: 'JJ/MM/AAAA',
                    text: 'Rhoncus morbi et augue nec, in id ullamcorper at sit. Condimentum sit nunc in eros scelerisque sed.',
                    author: 'Anonyme'
                },
                {
                    stars: '★★★★★',
                    date: 'JJ/MM/AAAA',
                    text: 'Rhoncus morbi et augue nec, in id ullamcorper at sit. Condimentum sit nunc in eros scelerisque sed.',
                    author: 'Anonyme'
                },
                {
                    stars: '★★★★★',
                    date: 'JJ/MM/AAAA',
                    text: 'Rhoncus morbi et augue nec, in id ullamcorper at sit. Condimentum sit nunc in eros scelerisque sed.',
                    author: 'Anonyme'
                }
            ] %}

            <div class="caviar-home-reviews__track" data-reviews-track>
                {% for testimonial in testimonials %}
                    <article class="caviar-home-review-card">
                        <div class="caviar-home-review-card__head">
                            <div class="caviar-home-review-card__stars" aria-hidden="true">{{ testimonial.stars }}</div>
                            <div class="caviar-home-review-card__date">{{ testimonial.date }}</div>
                        </div>
                        <p class="caviar-home-review-card__text">{{ testimonial.text }}</p>
                        <div class="caviar-home-review-card__foot">
                            <span class="caviar-home-review-card__author">{{ testimonial.author }}</span>
                            <span class="caviar-home-review-card__verified" aria-hidden="true">&#10038;</span>
                            <a href="#" class="caviar-home-review-card__more">Voir plus</a>
                        </div>
                    </article>
                {% endfor %}
            </div>

            <button class="caviar-home-reviews__arrow caviar-home-reviews__arrow--right" type="button" aria-label="Next reviews" data-reviews-next>&rsaquo;</button>
        </div>
    </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var tracks = document.querySelectorAll('[data-reviews-track]');
    if (!tracks.length) return;

    tracks.forEach(function (track) {
      var wrap = track.parentElement;
      var prevBtn = wrap.querySelector('[data-reviews-prev]');
      var nextBtn = wrap.querySelector('[data-reviews-next]');

      var getScrollAmount = function () {
        var firstCard = track.querySelector('.caviar-home-review-card');
        if (!firstCard) return 0;
        var cardWidth = firstCard.getBoundingClientRect().width;
        var gap = parseFloat(window.getComputedStyle(track).columnGap || window.getComputedStyle(track).gap || '0');
        return cardWidth + gap;
      };

      var updateArrows = function () {
        if (!prevBtn || !nextBtn) return;
        var maxScrollLeft = track.scrollWidth - track.clientWidth;
        prevBtn.disabled = track.scrollLeft <= 4;
        nextBtn.disabled = track.scrollLeft >= maxScrollLeft - 4;
      };

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        });
      }

      track.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows);
      updateArrows();
    });
  });
</script>
