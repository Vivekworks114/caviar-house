<section class="caviar-home-categories" aria-label="{{ 'CaviarTheme.home.categories.aria'|trans|sw_sanitize }}">
    {% set caviarCategoryImage = asset('bundles/caviartheme/assets/img/caviar.png') %}
    {% set saumonCategoryImage = asset('bundles/caviartheme/assets/img/saumon.png') %}
    <div class="caviar-home-categories__container">
        <div class="caviar-home-categories__intro">
            <h2 class="caviar-home-categories__title">CAVIAR HOUSE,<br>Placeholder</h2>
            <div class="caviar-home-categories__divider" aria-hidden="true"></div>
            <p class="caviar-home-categories__text">
                Découvrez notre sélection du produit,<br>
                pour un moment de dégustation<br>
                privilégié, à offrir ou à partager
            </p>
        </div>

        <div class="caviar-home-categories__gallery">
            {% set dynamicCategories = homeCategories ?? [] %}
            {% set baseSlides = dynamicCategories|length > 0 ? dynamicCategories|slice(0, 5) : [] %}
            {% set fallbackSlide = baseSlides|length > 0 ? baseSlides|first : null %}
            {% set fallbackSlides = [
                { image: caviarCategoryImage, name: 'Caviar' },
                { image: saumonCategoryImage, name: 'Saumon' }
            ] %}
            {% set slideCount = 5 %}

            <div class="caviar-home-categories__slides" data-categories-slider data-total="{{ slideCount }}">
                {% for index in 0..4 %}
                    {% set category = baseSlides[index] is defined ? baseSlides[index] : fallbackSlide %}
                    {% set fallbackCategory = fallbackSlides[index % (fallbackSlides|length)] %}
                    {% set categoryImage = category and category.media and category.media.url ? category.media.url : fallbackCategory.image %}
                    {% set categoryName = category and category.translated and category.translated.name ? category.translated.name : fallbackCategory.name %}
                    {% set categoryUrl = category and category.id ? seoUrl('frontend.navigation.page', { navigationId: category.id }) : '#' %}
                    <article class="caviar-home-categories__slide" data-slide-index="{{ index }}">
                        <a href="{{ categoryUrl }}" class="caviar-home-categories__slide-link">
                            <img
                                src="{{ categoryImage }}"
                                class="caviar-home-categories__slide-image"
                                alt="{{ categoryName }}"
                                loading="lazy"
                            >
                        </a>
                        <h3 class="caviar-home-categories__slide-label">{{ categoryName|upper }}</h3>
                    </article>
                {% endfor %}
            </div>

            <div class="caviar-home-categories__controls">
                <div class="caviar-home-categories__dots" data-slider-dots aria-hidden="true">
                    {% for dotIndex in 1..slideCount %}
                        <span class="{{ dotIndex == 1 ? 'is-active' : '' }}"></span>
                    {% endfor %}
                </div>
                <div class="caviar-home-categories__pager">
                    <button type="button" class="caviar-home-categories__pager-btn" data-slider-prev aria-label="Previous category">&lsaquo;</button>
                    <span class="is-active" data-slider-current>1 / {{ slideCount }}</span>
                    <button type="button" class="caviar-home-categories__pager-btn" data-slider-next aria-label="Next category">&rsaquo;</button>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var slider = document.querySelector('[data-categories-slider]');
    if (!slider) return;

    var slides = Array.prototype.slice.call(slider.querySelectorAll('[data-slide-index]'));
    var dotsWrap = slider.parentElement.querySelector('[data-slider-dots]');
    var dots = dotsWrap ? Array.prototype.slice.call(dotsWrap.querySelectorAll('span')) : [];
    var currentLabel = slider.parentElement.querySelector('[data-slider-current]');
    var prevBtn = slider.parentElement.querySelector('[data-slider-prev]');
    var nextBtn = slider.parentElement.querySelector('[data-slider-next]');
    var total = slides.length;
    var current = 0;

    if (!total) return;

    var render = function () {
      slides.forEach(function (slide, index) {
        var shouldShow = index === current || (total > 1 && index === (current + 1) % total);
        slide.style.display = shouldShow ? '' : 'none';
      });

      dots.forEach(function (dot, index) {
        dot.classList.toggle('is-active', index === current);
      });

      if (currentLabel) {
        currentLabel.textContent = (current + 1) + ' / ' + total;
      }
    };

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        current = (current - 1 + total) % total;
        render();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        current = (current + 1) % total;
        render();
      });
    }

    render();
  });
</script>
