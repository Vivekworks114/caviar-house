{% block sw_order_detail_details_payment_method_select %}
    <div>
        {% parent %}

        <template v-if="getLastOrderTransactionHandledViaSaferpay() && getLastOrderTransactionHandledViaSaferpay().customFields">
            <table>
                <tbody>
                    <tr style="background-color: #f3fcfb;">
                        <td style="padding: 8px; font-weight: 500; color: #46beaa;">Payment method</td>
                        <td style="padding: 8px;">{{ getLastOrderTransactionHandledViaSaferpay().customFields.worldline_saferpay_payment_method }}</td>
                    </tr>
                    <tr style="background-color: #f3fcfb;">
                        <td style="padding: 8px; font-weight: 500; color: #46beaa;">Transaction ID</td>
                        <td style="padding: 8px;">{{ getLastOrderTransactionHandledViaSaferpay().customFields.worldline_saferpay_transaction_id }}</td>
                    </tr>
                    <tr style="background-color: #f3fcfb;">
                        <td style="padding: 8px; font-weight: 500; color: #46beaa;">Capture ID</td>
                        <td style="padding: 8px;">{{ getLastOrderTransactionHandledViaSaferpay().customFields.worldline_saferpay_capture_id }}</td>
                    </tr>
                </tbody>
            </table>
        </template>

        <template v-if="getLastOrderTransactionHandledViaSaferpay() && getLastOrderTransactionHandledViaSaferpay().customFields && getLastOrderTransactionHandledViaSaferpay().customFields.worldline_saferpay_last_error">
            <div style="padding: 10px; background-color: #f8d7da; color: #721c24; border: solid 1px #f5c6cb; word-break: break-word;">
                {{ getLastOrderTransactionHandledViaSaferpay().customFields.worldline_saferpay_last_error }}
            </div>
        </template>
    </div>
{% endblock %}