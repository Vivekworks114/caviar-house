            <label lang="de-DE">Rückerstattungsreferenz</label>
            <helpText>
                Specifies which value should be transferred as the reference number for refunds.
            </helpText>
            <helpText lang="de-DE">
                Legt fest, welcher Wert als Referenznummer bei Rückerstattungen übergeben werden soll.
            </helpText>
            <options>
                <option>
                    <id>ORDER_NUMBER</id>
                    <name>Ordernumber</name>
                    <name lang="de-DE">Bestellnummer</name>
                </option>
                <option>
                    <id>ORDER_ID</id>
                    <name>Order ID</name>
                    <name lang="de-DE">ID der Bestellung</name>
                </option>
            </options>
            <defaultValue>ORDER_NUMBER</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Payment API (JSON API) live credentials</title>
        <title lang="de-DE">Payment API (JSON API) Live-Zugangsdaten</title>

        <input-field>
            <name>customerIdLive</name>
            <label>Customer ID (live)</label>
            <placeholder>456123</placeholder>
        </input-field>

        <input-field>
            <name>terminalIdLive</name>
            <label>Terminal ID (live)</label>
            <placeholder>17654321</placeholder>
        </input-field>

        <input-field>
            <name>usernameLive</name>
            <label lang="de-DE">Benutzername (live)</label>
            <label>Username</label>
            <placeholder>API_456123_87654321</placeholder>
        </input-field>

        <input-field>
            <name>passwordLive</name>
            <label lang="de-DE">Passwort (live)</label>
            <label>Password (live)</label>
            <placeholder>JsonApiPwd1_abcDEFGhI7Kl</placeholder>
        </input-field>

        <input-field>
            <name>saferpayFieldsAccessTokenLive</name>
            <label>Saferpay fields access token (live)</label>
            <placeholder>12345678-9fab-cdef-1234-0b38e7542af4</placeholder>
        </input-field>
    </card>

