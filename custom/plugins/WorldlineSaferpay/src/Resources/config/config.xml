    <card>
        <title>Payment data entry form</title>
        <title lang="de-DE">Eingabeformular für Zahlungsdaten</title>

        <input-field type="single-select">
            <name>paymentDataEntryFormCardHolderNameBehavior</name>
            <label>Card holder name</label>
            <label lang="de-DE">Name des Karteninhabers</label>
            <helpText>
                Defines whether the credit card holder must be entered in a form field or not (only applies to card payments).
            </helpText>
            <helpText lang="de-DE">
                Legt fest, ob der Kreditkarteninhaber in ein Formularfeld eingegeben werden muss oder nicht (betrifft nur Kartenzahlungen).
            </helpText>
            <options>
                <option>
                    <id>MANDATORY</id>
                    <name>Show as mandatory field</name>
                    <name lang="de-DE">Als Pflichtfeld anzeigen</name>
                </option>
                <option>
                    <id>NONE</id>
                    <name>Not shown</name>
                    <name lang="de-DE">Nicht anzeigen</name>
                </option>
            </options>
            <defaultValue>NONE</defaultValue>
        </input-field>
    </card>

