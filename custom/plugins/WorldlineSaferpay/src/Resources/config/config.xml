<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/master/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>General settings</title>
        <title lang="de-DE">Allgemeine Einstellungen</title>
        <input-field type="single-select">
            <name>operationMode</name>
            <label>Operation mode</label>
            <label lang="de-DE">Betriebsart</label>
            <options>
                <option>
                    <id>test</id>
                    <name>Test</name>
                </option>
                <option>
                    <id>live</id>
                    <name>Live</name>
                </option>
            </options>
            <defaultValue>test</defaultValue>
        </input-field>
        <input-field>
            <name>merchantEmails</name>
            <label>Merchant email addresses</label>
            <label lang="de-DE">Händler-E-Mail-Adressen</label>
            <placeholder>merchant@example.com, payment@example.com</placeholder>
            <helpText>
                List of merchant email addresses to which a confirmation email will be sent after successful payment authorizations.
                A maximum of 10 email addresses is allowed.
                Multiple email addresses must be separated by a comma.
            </helpText>
            <helpText lang="de-DE">
                Liste der Händler-E-Mail-Adressen, an die nach erfolgreicher Zahlungsautorisierung eine Bestätigungs-E-Mail gesendet wird.
                Es sind maximal 10 E-Mail-Adressen erlaubt.
                Mehrere E-Mail-Adressen müssen durch ein Komma getrennt werden.
            </helpText>
        </input-field>
        <input-field type="checkbox">
            <name>enableCustomerNotification</name>
            <label>Send Saferpay status notification emails to buyer</label>
            <label lang="de-DE">Saferpay Zahlungsbestätigungsemail an den Käufer senden</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Appeareance</title>
        <title lang="de-DE">Erscheinungsbild</title>
        <input-field>
            <name>paymentPageConfigName</name>
            <label>Payment page config name</label>
            <label lang="de-DE">Payment Page-Konfiguration</label>
            <helpText>
                Defines which payment page configuration (PPConfig) should be used. If empty, the default PPConfig will be used (if available).
                If the PPConfig cannot be found (e.g. wrong name), the Saferpay basic style will be applied.
            </helpText>
            <helpText lang="de-DE">
                Legt fest, welche Payment Page-Konfiguration (PPConfig) verwendet werden soll. Falls leer, wird die Standard-PPConfig verwendet (falls vorhanden).
                Wenn die PPConfig nicht gefunden werden kann (z.B. falscher Name), wird der Saferpay-Basisstil angewendet.
            </helpText>
        </input-field>
    </card>

    <card>
        <title>Payment behavior</title>
        <title lang="de-DE">Zahlungsverhalten</title>
        <input-field type="checkbox">
            <name>savePaymentData</name>
            <label>Save payment data</label>
            <label lang="de-DE">Zahlungsdaten speichern</label>
            <helpText>
                Defines whether the payment data should be saved for the next order (see https://docs.saferpay.com/home/integration-guide/licences-and-interfaces/secure-card-data).
            </helpText>
            <helpText lang="de-DE">
                Legt fest, ob die Zahlungsdaten für die nächste Bestellung gespeichert werden sollen (siehe https://docs.saferpay.com/home/integration-guide/licences-and-interfaces/secure-card-data).
            </helpText>
        </input-field>
        <input-field type="checkbox">
            <name>force3ds</name>
            <label>Force 3-D Secure</label>
            <label lang="de-DE">3-D Secure erzwingen</label>
            <helpText>
                Defines whether 3-D Secure is to be enforced (see https://docs.saferpay.com/home/integration-guide/licences-and-interfaces/general-information/3d-secure#forcing-a-3ds-challenge).
            </helpText>
            <helpText lang="de-DE">
                Legt fest, ob 3-D Secure erzwungen werden soll (siehe https://docs.saferpay.com/home/integration-guide/licences-and-interfaces/general-information/3d-secure#forcing-a-3ds-challenge).
            </helpText>
        </input-field>
        <input-field type="single-select">
            <name>paymentReference</name>
            <label>Payment reference</label>
            <label lang="de-DE">Zahlungsreferenz</label>
            <helpText>
                Specifies which value should be transferred as the reference number for payments.
            </helpText>
            <helpText lang="de-DE">
                Legt fest, welcher Wert als Referenznummer bei Zahlungen übergeben werden soll.
            </helpText>
            <options>
                <option>
                    <id>ORDER_NUMBER</id>
                    <name>Ordernumber</name>
                    <name lang="de-DE">Bestellnummer</name>
                </option>
                <option>
                    <id>ORDER_ID</id>
                    <name>Order ID</name>
                    <name lang="de-DE">ID der Bestellung</name>
                </option>
            </options>
            <defaultValue>ORDER_NUMBER</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Refund behavior</title>
        <title lang="de-DE">Rückerstattungsverhalten</title>
        <input-field type="single-select">
            <name>refundReference</name>
